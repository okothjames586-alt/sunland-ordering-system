# Server environment example for Sunland Ordering App

# Database
MONGODB_URI=mongodb://localhost:27017/sunland-ordering

# JWT
JWT_SECRET=your-super-secret-jwt-key

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Email (used for OTP and welcome emails)
# Examples: service 'gmail' or leave blank for custom SMTP settings
EMAIL_SERVICE=gmail
EMAIL_USER=youremail@example.com
EMAIL_PASSWORD=your-email-password-or-app-password

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payments
MPESA_BUSINESS_SHORT_CODE=your-mpesa-shortcode
MPESA_PASSKEY=your-mpesa-passkey
AIRTEL_API_KEY=your-airtel-api-key

# Debugging helpers (development only)
# When true, the server will return the generated OTP in the API response
# Use only for local testing. Do NOT enable in production.
DEBUG_RETURN_OTP=false
# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sunland-ordering

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Port Configuration
PORT=5000

# Client URL
CLIENT_URL=http://localhost:3000

# M-Pesa Configuration
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=your-m-pesa-passkey
MPESA_API_URL=https://api.safaricom.co.ke/mpesa

# Airtel Money Configuration
AIRTEL_API_URL=https://api.airtel.africa
AIRTEL_API_KEY=your-airtel-api-key

# Twilio Configuration (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# API URL (for callbacks)
API_URL=http://localhost:5000

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Admin bootstrap
TEST_ADMIN_NAME=Caleb Opala
TEST_ADMIN_EMAIL=opalacaleb@gmail.com
TEST_ADMIN_PHONE=0708206566
TEST_ADMIN_PASSWORD=woodvale
ADMIN_REGISTRATION_CODE=sunland-admin-2026